{
  "compilerOptions": {
    "target": "es5",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts", "src/api/topics/route.js", "src/api/topics/[id]/route.js", "src/components/List/TopicList.jsx", "src/components/tool/flow/Project/Project.jsx", "src/models/topic.js", "src/app/tool/flow/project/create/page.jsx", "src/app/tool/flow/project/edit/[id]/page.jsx", "src/constant/bar/dashboard.ts"],
  "exclude": ["node_modules"]
}
